# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# Choose between standard PostgreSQL and Supabase
USE_SUPABASE=false

# Standard PostgreSQL Configuration (if USE_SUPABASE=false)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=b2b_autoshipper
DB_USER=postgres
DB_PASSWORD=postgres

# Supabase Configuration (if USE_SUPABASE=true)
DATABASE_CONNECTION_STRING=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Shopify Configuration
SHOPIFY_SHOP_URL=your-shop.myshopify.com
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# SparkLayer Configuration
SPARKLAYER_SITE_ID=your_sparklayer_site_id
SPARKLAYER_API_KEY=your_sparklayer_api_key
SPARKLAYER_API_SECRET=your_sparklayer_api_secret

# AutoDS Configuration
AUTODS_API_KEY=your_autods_api_key
AUTODS_API_SECRET=your_autods_api_secret

# Syncee Configuration
SYNCEE_API_KEY=your_syncee_api_key
SYNCEE_API_SECRET=your_syncee_api_secret

# AfterShip Configuration
AFTERSHIP_API_KEY=your_aftership_api_key

# Monitoring (Optional)
SENTRY_DSN=
SLACK_WEBHOOK_URL=